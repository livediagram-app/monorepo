{
  "name": "@livediagram/live",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:webpack": "node scripts/dev.mjs --webpack",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next .next-dev out node_modules .turbo coverage"
  },
  "dependencies": {
    "@clerk/react": "^6.7.2",
    "@livediagram/api-schema": "workspace:*",
    "@livediagram/diagram": "workspace:*",
    "@livediagram/ui": "workspace:*",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@livediagram/eslint-config": "workspace:*",
    "@livediagram/tailwind-config": "workspace:*",
    "@livediagram/vitest-config": "workspace:*",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
