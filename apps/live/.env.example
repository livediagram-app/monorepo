# Live app environment variables.
#
# Anything prefixed `NEXT_PUBLIC_` is baked into the static export at
# build time and shipped to the browser. Everything else is build-only.
# Per spec 06 the repo is public, so never put secrets in NEXT_PUBLIC_
# variables.

# Where the live app calls the API. In production (Cloudflare) the
# router stitches the API onto the same hostname under `/api/*`, so
# leaving this unset is correct.
#
# For local development you'll want to override this:
#
# - Point at the deployed API (uses prod D1!):
#     NEXT_PUBLIC_API_BASE=https://www.livediagram.app/api
#
# - Point at a local `wrangler dev` of @livediagram/api:
#     NEXT_PUBLIC_API_BASE=http://localhost:8787/api
#
# Copy this file to `.env.local` and edit. `.env.local` is gitignored.
NEXT_PUBLIC_API_BASE=

# Clerk publishable key for the live app's auth provider. Optional:
# leaving this unset puts the deployment into pure-guest mode (see
# spec/04 + CLAUDE.md). The canvas, persistence, share links, and
# realtime collaboration all keep working because every code path
# also accepts an `X-Owner-Id` per-browser participant id; only the
# /live/sign-in and /live/get-started routes change, rendering an
# `AuthDisabledNotice` that points back to the editor. Self-hosters
# who want zero outbound runtime traffic can ship this empty. To
# turn sign-in on, get the key from the Clerk dashboard
# (https://dashboard.clerk.com → API Keys → Publishable key); format
# `pk_test_*` for dev tenants, `pk_live_*` for prod. Safe to commit
# / ship in client bundles (per Clerk docs + spec/06).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Shows the "Continue with Google" OAuth button on the sign-in and
# get-started pages when set to the literal string "true" (and only if
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is also set — the button is hidden
# in pure-guest mode). Before flipping this on, enable the Google SSO
# connection in the Clerk dashboard: dev tenants (`pk_test_*`) can use
# Clerk's shared Google credentials with no extra setup; prod
# (`pk_live_*`) needs your own Google Cloud OAuth client registered
# against Clerk's redirect URI (`https://clerk.<domain>/v1/oauth_callback`,
# shown verbatim in the Clerk dashboard). Leave unset to keep only the
# email-code flow. Safe to ship in client bundles.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=

# Anonymous, first-party usage telemetry switch (spec/22). When set to
# the literal string "true", `track(category, action, type?)` calls in
# the editor buffer events and POST them to `/api/events`. Anything
# else (including unset) makes `track()` a no-op so nothing leaves the
# browser. Self-host default is OFF: forks that don't want a usage
# dashboard get full silence without doing anything. Pair this with
# `TELEMETRY_ENABLED=true` on the api worker (the authoritative
# server-side gate) to actually turn the system on end-to-end. Users
# also have a per-device opt-out toggle in the Settings dialog
# (spec/20 `telemetryEnabled`) that overrides this when off.
NEXT_PUBLIC_TELEMETRY_ENABLED=

# Origin of the MCP server (spec/62), used by the live app to show the
# connect-an-AI-tool URLs and link out to it. Optional: leaving this
# unset defaults to the hosted `https://mcp.livediagram.app`
# (apps/live/lib/mcp-config.ts). Self-hosters who run their own MCP
# worker on a different host set it here (it must match the mcp worker's
# own host + its CONSENT_BASE_URL pointing back at this live app). Safe
# to ship in client bundles.
NEXT_PUBLIC_MCP_ORIGIN=
