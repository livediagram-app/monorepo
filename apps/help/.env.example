# Help centre environment variables.
#
# This app is a static export (spec/55). Anything prefixed
# NEXT_PUBLIC_ is baked into the build and shipped to the browser;
# per spec/06 the repo is public, so never put secrets here.

# Where the help app sends its anonymous telemetry events. In
# production the router stitches the api worker onto the same hostname
# under `/api/*`, so leaving this unset is correct (it falls back to
# the origin-relative '/api', which the router rewrites). For local
# development point it at a `wrangler dev` of @livediagram/api:
#     NEXT_PUBLIC_API_BASE=http://localhost:8787/api
NEXT_PUBLIC_API_BASE=

# Anonymous, first-party usage telemetry switch (spec/22), mirroring the
# live + telemetry apps. When set to the literal string "true" the help
# centre's `track()` buffers events and POSTs them to `/api/events`;
# anything else (including unset) makes it a no-op so nothing leaves the
# browser. Self-host default is OFF. Pair with `TELEMETRY_ENABLED=true`
# on the api worker (the authoritative server-side gate) to turn the
# system on end-to-end.
NEXT_PUBLIC_TELEMETRY_ENABLED=
