{
  "name": "@livediagram/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler node_modules .turbo coverage",
    "db:migrate:local": "wrangler d1 migrations apply livediagram --local",
    "db:migrate:remote": "wrangler d1 migrations apply livediagram --remote"
  },
  "dependencies": {
    "@livediagram/api-schema": "workspace:*",
    "@livediagram/diagram": "workspace:*",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@livediagram/eslint-config": "workspace:*",
    "@livediagram/vitest-config": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6",
    "wrangler": "^4.40.0"
  }
}
