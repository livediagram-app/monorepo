{
  "name": "@livediagram/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler node_modules .turbo",
    "db:migrate:local": "wrangler d1 migrations apply livediagram --local",
    "db:migrate:remote": "wrangler d1 migrations apply livediagram --remote"
  },
  "dependencies": {
    "@livediagram/diagram": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@livediagram/eslint-config": "workspace:*",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}
