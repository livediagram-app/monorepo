# API worker environment variables (spec/06).
#
# This worker runs on Cloudflare Workers, not Node. Local dev reads
# these from `apps/api/.dev.vars` (gitignored, see wrangler docs);
# production reads them from `wrangler.toml` [vars] for plain
# strings, and from `wrangler secret put` for secrets. This file is
# a copy-paste reference for what the worker consults at runtime,
# committed to the repo so contributors have one place to look.
#
# Per spec/06 the repo is public, so never put real secret values
# in this file: hex / token shapes are placeholders only.

# Clerk JWKS endpoint, used to verify Bearer tokens for the
# authed-owner path (spec/04). Unset = pure-guest mode; the worker
# still serves on X-Owner-Id alone. Drop into .dev.vars for local
# dev; provision via `wrangler secret put CLERK_JWKS_URL` in
# production.
#
# Teams (spec/32) additionally reads an optional `email` claim from
# the verified token to auto-connect pending invites. Add it via the
# Clerk dashboard's session-token customisation:
#   { "email": "{{user.primary_email_address}}" }
# No env var needed — it travels inside the JWT.
# CLERK_JWKS_URL=https://clerk-instance.example/.well-known/jwks.json

# Optional: when set, the Clerk verifier also asserts the token's `iss`
# claim, so a validly-signed token from a different Clerk instance that
# happens to share the JWKS host can't be replayed. Unset = issuer not
# asserted (back-compat). Set it to your instance's issuer URL.
# CLERK_ISSUER=https://clerk-instance.example

# Optional: when set, the Clerk verifier also asserts the token's `aud`
# claim, so a token minted for a different audience/app can't be replayed
# here. Unset = audience not asserted (back-compat). Set it to the audience
# you configure in Clerk for this API.
# CLERK_AUDIENCE=livediagram-api

# HMAC secret for signing guest owner-ids (spec/04). When set, the worker
# mints signed guest ids (POST /api/guest-id) and /api/migrate requires a
# valid signature before reassigning a guest's data to a Clerk account —
# so observing a guest's id (which leaks via DTOs / presence) is not enough
# to claim its data. Strongly recommended whenever Clerk is configured.
# Unset = legacy unsigned migrate (acceptable for a single-user self-host).
# Use a long random value: `openssl rand -hex 32`. Provision like
# CLERK_JWKS_URL (.dev.vars locally, `wrangler secret put` in prod).
# GUEST_ID_HMAC_SECRET=replace-with-openssl-rand-hex-32

# Anonymous telemetry ingest + dashboard (spec/22). Only the literal
# string "true" enables both. Unset / "false" / anything else keeps
# the events route accepting and dropping POSTs (204 with no D1
# write) and the dashboard route returning empty totals, so OSS
# self-host stays silent by default.
# TELEMETRY_ENABLED=true

# OpenAI integration for the AI assistance feature (spec/25).
# OPENAI_API_KEY is a worker secret; absent = the AI surface hides
# entirely (capabilities returns aiEnabled: false, /api/ai returns
# 503). OPENAI_MODEL is an optional [vars] override; defaults to
# gpt-4o.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Optional spend-DoS defences on /api/ai (spec/25). Both default to
# "off" so OSS self-hosters keep the historical open behaviour.
# Hosted livediagram.app sets both.
# AI_ALLOWED_ORIGINS=https://livediagram.app,http://localhost:3002
# AI_REQUIRE_CLERK=true

# Optional per-owner soft caps on the image gallery (spec/19). Both
# decimal strings; unset / 0 / non-numeric = no limit. Hosted
# livediagram.app sets these to 100 and 104857600 (100 MB) so one
# owner can't drain the R2 bucket. POST /api/images returns 403
# { error: "gallery_full" } when either cap is hit.
# IMAGE_MAX_PER_OWNER=100
# IMAGE_MAX_BYTES_PER_OWNER=104857600
