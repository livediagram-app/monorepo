    "@livediagram/diagram": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "hono": "^4.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@livediagram/eslint-config": "workspace:*",
    "@livediagram/vitest-config": "workspace:*",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6",
    "wrangler": "^4.40.0"
  }
}
