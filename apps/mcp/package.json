{
  "name": "@livediagram/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
